# ── Database ──────────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=<generate-a-random-password>
PG_DB=aifut
DATABASE_URL=postgresql://${PG_USER}:${PG_PASSWORD}@postgres:5432/${PG_DB}

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=<generate-a-random-64-char-secret>
JWT_EXPIRES_IN=7d

# ── API ───────────────────────────────────────────────
API_PORT=3002

# ── Web ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.app
