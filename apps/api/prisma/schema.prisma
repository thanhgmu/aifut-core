generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

enum SessionType {
  PASSWORD
  MAGIC_LINK
  OAUTH
  API_KEY
  SERVICE
}

enum IntegrationCategory {
  STORAGE
  DATABASE
  WORKFLOW
  AI
  COMMUNICATION
  ANALYTICS
  PAYMENTS
  OTHER
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
  ERROR
}

enum EntitlementKind {
  FEATURE
  LIMIT
  STORAGE
  USAGE_CREDIT
}

enum TenantDomainKind {
  PLATFORM_SUBDOMAIN
  CUSTOM
  AFFILIATE_DOMAIN
}

enum TenantDomainStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
}

enum TenantStorageMode {
  PLATFORM_MANAGED
  TENANT_MANAGED
  HYBRID
  DISABLED
}

enum AuditActorType {
  USER
  SYSTEM
  SERVICE
}

enum AuditSeverity {
  INFO
  WARN
  CRITICAL
}

model Tenant {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  workspaces               Workspace[]
  users                    User[]
  memberships              Membership[]
  sessions                 Session[]
  integrations             IntegrationConnection[]
  entitlements             Entitlement[]
  auditEvents              AuditEvent[]
  auditLogs                AuditLog[]
  domains                  TenantDomain[]
  storagePolicies          TenantStoragePolicy[]
  packageAssignments       TenantPackageAssignment[]
  workflowTemplates        WorkflowTemplate[]
  workflowExecutions       WorkflowExecution[]
  backupSchedules          BackupSchedule[]
  backupJobs               BackupJob[]
  billingAccount           BillingAccount?
  subscriptions            Subscription[]
  invoices                 Invoice[]
  usageRecords             UsageRecord[]
  paymentTransactions      PaymentTransaction[]
  marketplaceListings      MarketplaceListing[]
  resellerAccount          ResellerAccount?
  notificationLogs         NotificationLog[]
  notificationTemplates    NotificationTemplate[]
  affiliateAccount         AffiliateAccount?
  zaloConnection           ZaloOaConnection?
  zaloSentMessages         ZaloSentMessage[]
  zaloWebhookEvents        ZaloWebhookEvent[]
  certifications           ConnectorCertification[]
  eInvoices                EInvoice[]
  wallet                   Wallet?
  ledgerTransactions       LedgerTransaction[]
  refundRecords            RefundRecord[]
  aiBudgetLimits           AiBudgetLimit[]
  budgetAccumulationLogs   BudgetAccumulationLog[]
  tenantAnalyticsSummaries TenantAnalyticsSummary[]
  anomalyRecords           AnomalyRecord[]
  developerProfiles        DeveloperProfile[]
  licenseKeys              LicenseKey[]
}

model Workspace {
  id                 String                    @id @default(cuid())
  name               String
  slug               String
  tenantId           String
  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  integrations       IntegrationConnection[]
  domains            TenantDomain[]
  storagePolicies    TenantStoragePolicy[]
  packageAssignments TenantPackageAssignment[]
  workflowTemplates  WorkflowTemplate[]
  workflowExecutions WorkflowExecution[]
  backupSchedules    BackupSchedule[]
  backupJobs         BackupJob[]
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([tenantId, slug])
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  passwordHash String?
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships  Membership[]
  sessions     Session[]
  auditEvents  AuditEvent[]
  auditLogs    AuditLog[]   @relation("AuditActorLogs")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Membership {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  role        MembershipRole
  isDefault   Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([tenantId, userId, workspaceId, role])
  @@index([tenantId, userId])
  @@index([workspaceId])
}

model Session {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        SessionType
  name        String? // human-readable name for API keys
  scopes      Json        @default("[]") // API key scopes: 'read', 'write', 'admin'
  tokenHash   String      @unique
  refreshHash String?
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model IntegrationConnection {
  id                String              @id @default(cuid())
  tenantId          String
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name              String
  slug              String
  category          IntegrationCategory
  provider          String
  status            ConnectionStatus    @default(PENDING)
  config            Json?
  secretsRef        String?
  mappingMode       String?
  mappedObjects     Json                @default("[]")
  fieldMappings     Json?
  eventMappings     Json?
  syncPolicy        Json?
  routingMode       String?
  targetBaseUrl     String?
  targetEnvironment String?
  targetRegion      String?
  lastVerifiedAt    DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, category])
  @@index([workspaceId])
}

model Entitlement {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  kind      EntitlementKind
  value     String
  source    String?
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([tenantId, key])
}

model AuditEvent {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // в”Ђв”Ђ Actor identity в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  userId     String?
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType  AuditActorType
  actorEmail String? // NEW вЂ” snapshot email tбєЎi thб»ќi Д‘iб»ѓm ghi (immutable kб»ѓ cбєЈ khi user bб»‹ xГіa)

  // в”Ђв”Ђ Action metadata в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  action     String
  targetType String?
  targetId   String?

  // в”Ђв”Ђ Context (mб»›i) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  ipAddress String? // NEW вЂ” client IP tб»« request
  userAgent String? // NEW вЂ” User-Agent header
  sessionId String? // NEW вЂ” session ID nбєїu cГі

  // в”Ђв”Ђ Payload diff (mб»›i) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  oldValue Json? // NEW вЂ” dб»Ї liб»‡u trЖ°б»›c khi thay Д‘б»•i
  newValue Json? // NEW вЂ” dб»Ї liб»‡u sau khi thay Д‘б»•i

  // в”Ђв”Ђ Metadata mб»џ rб»™ng в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  metadata Json?
  severity AuditSeverity? // NEW вЂ” INFO в”‚ WARN в”‚ CRITICAL

  // в”Ђв”Ђ Timestamps (immutable вЂ” khГґng cГі updatedAt) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  createdAt DateTime @default(now())

  @@index([tenantId, action])
  @@index([userId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, actorEmail])
  @@index([tenantId, severity])
  @@index([tenantId, targetType, targetId])
  @@index([action])
  @@index([actorEmail])
  @@index([sessionId])
  @@index([createdAt])
}

model TenantDomain {
  id                String             @id @default(cuid())
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  hostname          String
  kind              TenantDomainKind
  status            TenantDomainStatus @default(PENDING)
  isPrimary         Boolean            @default(false)
  provider          String?
  provisioningMode  String?
  dnsTarget         String?
  certificateStatus String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([hostname])
  @@index([tenantId, status])
  @@index([workspaceId])
}

model TenantStoragePolicy {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId     String?
  workspace       Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  key             String
  mode            TenantStorageMode
  storageClass    String?
  targetRef       String?
  targetRegion    String?
  backupTargetRef String?
  meteringEnabled Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, mode])
  @@index([workspaceId])
}

model TenantPackageAssignment {
  id                String     @id @default(cuid())
  tenantId          String
  tenant            Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  scopeKey          String     @unique
  basePlanKey       String
  selectedOptions   Json       @default("[]")
  billingSnapshot   Json?
  provisioningState String?
  source            String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([tenantId, basePlanKey])
  @@index([workspaceId])
}

model OrchestrationRuntimeSnapshot {
  id              String   @id @default(cuid())
  snapshotKey     String   @unique
  planId          String
  snapshotType    String
  runtimeStatus   String
  tenantSlug      String
  workspaceSlug   String?
  recordedBy      String
  recordedAt      DateTime
  contractSummary Json
  summary         Json
  mutationRecords Json
  eventRecords    Json
  createdAt       DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, snapshotType])
  @@index([recordedAt])
}

model OrchestrationRuntimeEvent {
  id            String   @id @default(cuid())
  eventKey      String   @unique
  planId        String
  eventType     String
  runtimeStatus String
  tenantSlug    String
  workspaceSlug String?
  actorKey      String
  relatedKeys   Json
  metadata      Json
  recordedAt    DateTime
  createdAt     DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, eventType])
  @@index([recordedAt])
}

model AiRoutingPolicy {
  id                       String   @id @default(cuid())
  policyKey                String   @unique
  scopeType                String
  tenantSlug               String
  workspaceSlug            String?
  featureKey               String
  taskType                 String
  defaultLane              String
  maxLane                  String
  preferredCredentialMode  String
  allowByoKeys             Boolean  @default(false)
  requireApprovalAboveLane String?
  downgradeAtQuotaPressure String
  cacheEnabled             Boolean  @default(true)
  deterministicFirst       Boolean  @default(true)
  source                   String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([tenantSlug, featureKey])
  @@index([workspaceSlug])
  @@index([defaultLane])
}

model AiBudgetPolicy {
  id                             String   @id @default(cuid())
  policyKey                      String   @unique
  scopeType                      String
  tenantSlug                     String
  workspaceSlug                  String?
  featureKey                     String
  monthlyTokenBudget             Int      @default(0)
  hardMonthlyTokenLimit          Int      @default(0)
  premiumExecutionCap            Int      @default(0)
  blockOnHardLimit               Boolean  @default(true)
  requireApprovalAtProjectedCost Float    @default(0)
  source                         String
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  @@index([tenantSlug, featureKey])
  @@index([workspaceSlug])
}

model AiUsageEvent {
  id              String   @id @default(cuid())
  eventKey        String   @unique
  scopeType       String
  tenantSlug      String
  workspaceSlug   String?
  actorKey        String
  featureKey      String
  taskType        String
  providerKey     String
  modelKey        String
  credentialMode  String
  executionLane   String
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  totalTokens     Int      @default(0)
  estimatedCost   Float    @default(0)
  actualCost      Float    @default(0)
  cacheHit        Boolean  @default(false)
  retryCount      Int      @default(0)
  escalationCount Int      @default(0)
  status          String
  source          String
  occurredAt      DateTime
  createdAt       DateTime @default(now())

  @@index([tenantSlug, occurredAt])
  @@index([workspaceSlug])
  @@index([featureKey, taskType])
  @@index([executionLane])
  @@index([status])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  DISABLED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum WorkflowNodeType {
  TRIGGER
  ACTION
  CONDITION
  WAIT
  SEND
  TRANSFORM
  LOOP
  SUB_WORKFLOW
}

enum WorkflowTriggerKind {
  SCHEDULE
  WEBHOOK
  EVENT
  MANUAL
}

model WorkflowTemplate {
  id                String         @id @default(cuid())
  tenantId          String
  workspaceId       String?
  key               String
  name              String
  description       String?
  category          String?
  industry          String?
  status            WorkflowStatus @default(DRAFT)
  version           Int            @default(1)
  tags              Json           @default("[]")
  metadata          Json?
  source            String?
  isPublic          Boolean        @default(false)
  marketplaceStatus String         @default("DRAFT")
  developerNotes    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  nodes      WorkflowNode[]
  executions WorkflowExecution[]
  triggers   WorkflowTrigger[]

  @@unique([tenantId, key])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([industry])
}

model WorkflowNode {
  id             String           @id @default(cuid())
  workflowId     String
  key            String
  name           String
  nodeType       WorkflowNodeType
  position       Int              @default(0)
  config         Json?
  inputMapping   Json?
  outputMapping  Json?
  retryPolicy    Json?
  timeoutSeconds Int              @default(300)
  dependsOn      Json             @default("[]")
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workflow WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([workflowId, nodeType])
  @@index([workflowId, position])
}

model WorkflowTrigger {
  id            String              @id @default(cuid())
  workflowId    String
  kind          WorkflowTriggerKind
  config        Json?
  schedule      String? // cron expression
  webhookSecret String?
  eventType     String?
  enabled       Boolean             @default(true)
  lastFiredAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  workflow WorkflowTemplate @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, kind])
  @@index([eventType])
}

model WorkflowExecution {
  id          String                  @id @default(cuid())
  workflowId  String
  tenantId    String
  workspaceId String?
  triggerKind WorkflowTriggerKind?
  triggeredBy String?
  status      WorkflowExecutionStatus @default(PENDING)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  timeoutAt   DateTime?
  retryCount  Int                     @default(0)
  maxRetries  Int                     @default(3)
  metadata    Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  workflow  WorkflowTemplate        @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  steps     WorkflowExecutionStep[]

  @@index([workflowId, status])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([triggerKind])
}

model WorkflowExecutionStep {
  id          String                  @id @default(cuid())
  executionId String
  nodeId      String?
  nodeKey     String
  status      WorkflowExecutionStatus @default(PENDING)
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  retryCount  Int                     @default(0)
  metadata    Json?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, nodeKey])
  @@index([executionId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditActorLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

enum BackupJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

model BackupSchedule {
  id             String    @id @default(cuid())
  tenantId       String
  workspaceId    String?
  key            String
  name           String
  description    String?
  cronExpression String? // null = manual only
  targetRef      String // storage target reference
  backupMode     String // 'full', 'incremental', 'diff'
  retentionDays  Int       @default(30)
  maxBackups     Int       @default(10)
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastStatus     String?
  config         Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  jobs      BackupJob[]

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
  @@index([workspaceId])
}

model BackupJob {
  id           String          @id @default(cuid())
  scheduleId   String
  tenantId     String
  workspaceId  String?
  status       BackupJobStatus @default(PENDING)
  backupTarget String?
  startedAt    DateTime?
  completedAt  DateTime?
  totalSize    Int? // bytes
  fileCount    Int?
  error        String?
  log          String?
  retryCount   Int             @default(0)
  triggeredBy  String? // 'schedule', 'manual', 'api'
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  schedule  BackupSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([scheduleId, status])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([startedAt])
}

model BillingAccount {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  currency        String    @default("VND")
  balance         Float     @default(0)
  billingEmail    String?
  paymentMethod   String?
  nextBillingDate DateTime?
  billingPeriod   String    @default("monthly") // monthly, yearly, one-time
  status          String    @default("active") // active, past_due, suspended, cancelled
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions       Subscription[]
  invoices            Invoice[]
  usageRecords        UsageRecord[]
  paymentTransactions PaymentTransaction[]
}

enum BillingInterval {
  MONTHLY
  YEARLY
  ONE_TIME
}

model SubscriptionPlan {
  id             String          @id @default(cuid())
  key            String          @unique
  name           String
  description    String?
  price          Float
  currency       String          @default("VND")
  interval       BillingInterval @default(MONTHLY)
  features       Json? // feature flags
  limits         Json? // usage limits
  maxUsers       Int             @default(1)
  maxWorkflows   Int             @default(5)
  aiCallsMonthly Int             @default(1000)
  storageGB      Int             @default(10)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id          String    @id @default(cuid())
  accountId   String
  planKey     String
  tenantId    String
  status      String    @default("active") // active, trialing, past_due, cancelled, expired
  startedAt   DateTime?
  expiresAt   DateTime?
  autoRenew   Boolean   @default(true)
  trialEndsAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  account  BillingAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planKey], references: [key])
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices Invoice[]

  @@index([accountId, status])
  @@index([tenantId, status])
  @@index([planKey])
}

model Invoice {
  id             String    @id @default(cuid())
  accountId      String
  subscriptionId String?
  tenantId       String
  number         String    @unique
  amount         Float
  currency       String    @default("VND")
  status         String    @default("pending") // pending, paid, failed, refunded
  description    String?
  dueDate        DateTime?
  paidAt         DateTime?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  account      BillingAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  subscription Subscription?        @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments     PaymentTransaction[]

  @@index([accountId, status])
  @@index([tenantId, status])
  @@index([dueDate])
}

model PaymentTransaction {
  id            String    @id @default(cuid())
  invoiceId     String?
  accountId     String
  tenantId      String
  gateway       String // 'vnpay' | 'momo' | 'stripe' | 'manual'
  gatewayTxId   String? // transaction ID from payment gateway
  amount        Float
  currency      String    @default("VND")
  status        String    @default("pending") // pending, success, failed, refunded
  paymentMethod String? // 'qr', 'card', 'bank', 'wallet'
  paymentUrl    String? // URL to redirect user for payment
  paidAt        DateTime?
  metadata      Json?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invoice Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  account BillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([tenantId, createdAt])
  @@index([gateway, gatewayTxId])
  @@index([status])
}

model UsageRecord {
  id         String   @id @default(cuid())
  accountId  String
  tenantId   String
  category   String // 'ai', 'storage', 'workflow', 'notification'
  metric     String // 'tokens', 'mb', 'executions', 'messages'
  value      Float
  recordedAt DateTime
  metadata   Json?
  createdAt  DateTime @default(now())

  account BillingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([accountId, category])
  @@index([tenantId, recordedAt])
  @@index([category, recordedAt])
}

model ResellerAccount {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  status          String   @default("active") // active, suspended, pending
  commissionRate  Float    @default(0.2) // 20%
  commissionType  String   @default("recurring") // recurring, one-time
  discountRate    Float    @default(0.3) // 30% for reseller pricing
  subTenantCount  Int      @default(0)
  totalCommission Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subTenants ResellerSubTenant[]
}

model ResellerSubTenant {
  id               String   @id @default(cuid())
  resellerId       String
  subTenantSlug    String
  subTenantName    String
  status           String   @default("active")
  subscriptionKey  String?
  revenueAmount    Float    @default(0)
  commissionEarned Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  reseller ResellerAccount @relation(fields: [resellerId], references: [id], onDelete: Cascade)

  @@index([resellerId, status])
}

model MarketplaceListing {
  id          String   @id @default(cuid())
  tenantId    String?
  type        String // 'connector', 'template', 'workflow'
  key         String   @unique
  name        String
  description String?
  category    String?
  industry    String?
  region      String?  @default("VN") // connector quoc gia: VN, SG, US, JP, TH
  price       Float    @default(0)
  currency    String   @default("VND")
  authorName  String?
  authorEmail String?
  version     String   @default("1.0.0")
  tags        Json     @default("[]")
  config      Json?
  downloads   Int      @default(0)
  rating      Float?
  isPublished Boolean  @default(false)
  isOfficial  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant?                    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  ratings MarketplaceListingRating[]
  orders  MarketplaceOrder[]

  @@index([type, category])
  @@index([isPublished])
  @@index([industry])
  @@index([region])
  @@index([downloads])
}

model MarketplaceListingRating {
  id        String   @id @default(cuid())
  listingId String
  tenantId  String
  rating    Int // 1-5
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, tenantId])
  @@index([listingId])
  @@index([tenantId])
}

enum NotificationChannel {
  EMAIL
  WEBHOOK
  SMS
  ZALO
  SLACK
  LOG
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

model NotificationTemplate {
  id              String              @id @default(cuid())
  tenantId        String
  key             String // unique slug per tenant, e.g. "welcome-email"
  name            String // human-readable name
  channel         NotificationChannel
  subjectTemplate String? // optional subject template with {{placeholders}}
  bodyTemplate    String // body with {{placeholders}}, supports HTML
  format          String              @default("text") // "text" | "html" | "markdown"
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}

model NotificationLog {
  id                String              @id @default(cuid())
  tenantId          String
  userId            String?
  channel           NotificationChannel
  to                String
  subject           String?
  templateKey       String?
  renderedBody      String?
  status            NotificationStatus  @default(PENDING)
  provider          String?
  providerMessageId String?
  error             String?
  durationMs        Int?
  metadata          Json?
  executionId       String?
  executionStepId   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, channel, status])
  @@index([executionId])
}

// в”Ђв”Ђ Zalo OA Integration в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum ZaloOaConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum ZaloMessageType {
  TEXT
  ZNS_TEMPLATE
  MEDIA
  STICKER
}

enum ZaloMessageSendStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

model ZaloOaConnection {
  id                    String                 @id @default(cuid())
  tenantId              String                 @unique
  oaId                  String
  appId                 String
  encryptedSecret       String
  encryptedRefreshToken String
  encryptedAccessToken  String?
  tokenExpiresAt        DateTime?
  status                ZaloOaConnectionStatus @default(ACTIVE)
  lastVerifiedAt        DateTime?
  dailyQuotaTotal       Int                    @default(0)
  dailyQuotaUsed        Int                    @default(0)
  quotaResetAt          DateTime?
  webhookSecret         String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentMessages  ZaloSentMessage[]
  webhookEvents ZaloWebhookEvent[]

  @@index([oaId])
  @@index([status])
}

model ZaloSentMessage {
  id            String                @id @default(cuid())
  connectionId  String
  tenantId      String
  messageType   ZaloMessageType
  templateId    String?
  recipientId   String
  templateData  Json?
  content       String?
  zaloMessageId String?
  sendStatus    ZaloMessageSendStatus @default(PENDING)
  errorCode     Int?
  errorMessage  String?
  quotaCost     Int                   @default(1)
  sentAt        DateTime              @default(now())
  deliveredAt   DateTime?
  readAt        DateTime?
  metadata      Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  connection ZaloOaConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([connectionId, sentAt])
  @@index([tenantId, sentAt])
  @@index([zaloMessageId])
  @@index([sendStatus])
}

model ZaloWebhookEvent {
  id           String    @id @default(cuid())
  connectionId String?
  tenantId     String?
  eventName    String
  payload      Json
  processed    Boolean   @default(false)
  processedAt  DateTime?
  error        String?
  receivedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  connection ZaloOaConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([eventName, receivedAt])
  @@index([connectionId])
  @@index([processed])
}

// в”Ђв”Ђ Affiliate / Commission System в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum AffiliateStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DISABLED
}

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model AffiliateAccount {
  id               String          @id @default(cuid())
  tenantId         String          @unique
  status           AffiliateStatus @default(PENDING)
  referralCode     String          @unique
  commissionRate   Float           @default(0.1) // 10% default
  commissionType   CommissionType  @default(PERCENTAGE)
  totalEarned      Float           @default(0)
  totalPaid        Float           @default(0)
  totalConversions Int             @default(0)
  payoutMethod     String? // 'bank', 'momo', 'paypal'
  payoutDetails    String? // account number, email, etc.
  cookieDays       Int             @default(30) // attribution window
  autoApprove      Boolean         @default(false)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links       AffiliateLink[]
  conversions AffiliateConversion[]
  payouts     CommissionPayout[]
}

model AffiliateLink {
  id              String   @id @default(cuid())
  accountId       String
  key             String   @unique // short code, e.g. "thuonghieu-2026"
  label           String // human-readable, e.g. "BГ i blog thГЎng 6"
  targetUrl       String // where the link points
  destination     String? // 'landing', 'pricing', 'signup', 'checkout', 'custom'
  campaign        String? // utm campaign or internal campaign name
  isActive        Boolean  @default(true)
  clickCount      Int      @default(0)
  conversionCount Int      @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account     AffiliateAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversions AffiliateConversion[]

  @@index([accountId, isActive])
  @@index([campaign])
}

model AffiliateConversion {
  id               String           @id @default(cuid())
  accountId        String
  linkId           String?
  tenantId         String? // the converted tenant (nullable if pre-registration)
  customerEmail    String? // email of converted user
  customerName     String?
  conversionType   String // 'signup', 'subscription', 'payment', 'trial'
  commissionAmount Float            @default(0)
  commissionStatus CommissionStatus @default(PENDING)
  revenueAmount    Float            @default(0) // total revenue from this conversion
  currency         String           @default("VND")
  referralCode     String? // captured from the link
  ipAddress        String?
  userAgent        String?
  attributedAt     DateTime         @default(now())
  convertedAt      DateTime? // when the actual conversion event happened
  expiresAt        DateTime? // cookie attribution expiry
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  account AffiliateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  link    AffiliateLink?   @relation(fields: [linkId], references: [id], onDelete: SetNull)

  @@index([accountId, commissionStatus])
  @@index([linkId])
  @@index([tenantId])
  @@index([referralCode])
  @@index([attributedAt])
}

model CommissionPayout {
  id              String           @id @default(cuid())
  accountId       String
  amount          Float
  currency        String           @default("VND")
  status          CommissionStatus @default(PENDING)
  payoutMethod    String? // snapshot of method at time of payout
  payoutReference String? // transaction ID from payment provider
  periodStart     DateTime?
  periodEnd       DateTime?
  notes           String?
  conversionIds   Json             @default("[]") // references to AffiliateConversion ids
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  account AffiliateAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([createdAt])
}

// в”Ђв”Ђ Connector Certification Program в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum CertificationStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

model ConnectorCertification {
  id               String              @id @default(cuid())
  tenantId         String
  connectorKey     String
  connectorName    String
  version          String              @default("1.0.0")
  developerEmail   String?
  developerName    String?
  status           CertificationStatus @default(SUBMITTED)
  checklistResults Json? // JSON array of { id, name, passed, notes }
  reviewerNotes    String?
  reviewedBy       String?
  submittedAt      DateTime            @default(now())
  reviewedAt       DateTime?
  badgeUrl         String?
  expiresAt        DateTime? // certification validity, 1 year default
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, connectorKey])
  @@index([status])
  @@index([tenantId])
  @@index([submittedAt])
