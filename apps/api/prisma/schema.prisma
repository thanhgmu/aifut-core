generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

enum SessionType {
  PASSWORD
  MAGIC_LINK
  OAUTH
  API_KEY
  SERVICE
}

enum IntegrationCategory {
  STORAGE
  DATABASE
  WORKFLOW
  AI
  COMMUNICATION
  ANALYTICS
  PAYMENTS
  OTHER
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
  ERROR
}

enum EntitlementKind {
  FEATURE
  LIMIT
  STORAGE
  USAGE_CREDIT
}

enum AuditActorType {
  USER
  SYSTEM
  SERVICE
}

model Tenant {
  id          String                  @id @default(cuid())
  name        String
  slug        String                  @unique
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  workspaces  Workspace[]
  users       User[]
  memberships Membership[]
  sessions    Session[]
  integrations IntegrationConnection[]
  entitlements Entitlement[]
  auditEvents AuditEvent[]
}

model Workspace {
  id           String                  @id @default(cuid())
  name         String
  slug         String
  tenantId     String
  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships  Membership[]
  integrations IntegrationConnection[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@unique([tenantId, slug])
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  sessions      Session[]
  auditEvents   AuditEvent[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Membership {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String?
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  role         MembershipRole
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([tenantId, userId, workspaceId, role])
  @@index([tenantId, userId])
  @@index([workspaceId])
}

model Session {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           SessionType
  tokenHash      String       @unique
  refreshHash    String?
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model IntegrationConnection {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId     String?
  workspace       Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name            String
  slug            String
  category        IntegrationCategory
  provider        String
  status          ConnectionStatus    @default(PENDING)
  config          Json?
  secretsRef      String?
  mappingMode     String?
  mappedObjects   String[]            @default([])
  fieldMappings   Json?
  eventMappings   Json?
  syncPolicy      Json?
  lastVerifiedAt  DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, category])
  @@index([workspaceId])
}

model Entitlement {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  kind        EntitlementKind
  value       String
  source      String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, key])
}

model AuditEvent {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType     AuditActorType
  action        String
  targetType    String?
  targetId      String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([tenantId, action])
  @@index([userId])
  @@index([createdAt])
}
