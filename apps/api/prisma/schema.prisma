  anomalyType AnomalyType
  severity    AnomalySeverity @default(MEDIUM)

  // в”Ђв”Ђ MГґ tбєЈ в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  title       String
  description String?
  detailsJson Json?

  // в”Ђв”Ђ Metric snapshot в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  metricName     String?
  metricValue    Float?
  baselineValue  Float?
  industryAvg    Float?
  deviationScore Float?

  // в”Ђв”Ђ Resolved в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  isResolved Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?

  // в”Ђв”Ђ Notification в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  notifiedAt     DateTime?
  acknowledgedAt DateTime?

  // в”Ђв”Ђ Timestamps в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  detectedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // в”Ђв”Ђ Constraints в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  @@index([tenantId, severity])
  @@index([tenantId, anomalyType])
  @@index([tenantId, isResolved])
  @@index([tenantId, detectedAt])
  @@index([severity, isResolved])
  @@index([anomalyType])
  @@index([detectedAt])
}

// в”Ђв”Ђ Phase 4: Developer Profile & Marketplace Economics в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Developer identity profile for marketplace listings + certification
// Module: apps/api/src/developer/

enum DeveloperStatus {
  ACTIVE
  INACTIVE
  VERIFIED
  BANNED
}

enum DeveloperTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum OrderStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
  CANCELLED
}

model DeveloperProfile {
  id        String          @id @default(uuid())
  tenantId  String          @unique
  userId    String?
  displayName String
  bio       String?
  avatarUrl String?
  company   String?
  website   String?
  githubUrl String?
  twitterUrl String?
  country   String?         @default("VN")
  languages String[]        @default([])
  status    DeveloperStatus @default(ACTIVE)
  tier      DeveloperTier   @default(BRONZE)
  totalListings Int         @default(0)
  totalSales   Int          @default(0)
  totalEarnings BigInt      @default(0)
  rating    Float?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  skills    DeveloperSkill[]
  earnings  DeveloperEarning[]

  @@index([tenantId, status])
  @@index([tier])
  @@index([totalSales])
}

model DeveloperSkill {
  id          String   @id @default(uuid())
  profileId   String
  skill       String   // e.g. "Python", "REST API", "AI/ML"
  level       Int      @default(3) // 1-5
  createdAt   DateTime @default(now())

  profile DeveloperProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, skill])
  @@index([skill])
}

model MarketplaceOrder {
  id          String      @id @default(uuid())
  listingId   String
  buyerTenantId String
  listingKey  String
  listingName String
  listingType String      // 'connector' | 'template' | 'workflow'
  amount      BigInt      // price in smallest unit (VND)
  currency    String      @default("VND")
  fxRateSnapshot Float?   // frozen rate at purchase time
  revenueShare Float       @default(0.7) // 70% dev, 30% platform
  devEarnings BigInt      @default(0)
  platformFee BigInt      @default(0)
  status      OrderStatus @default(PENDING)
  orderRef    String?     // unique order reference
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Restrict)

  @@unique([listingKey, buyerTenantId])
  @@index([buyerTenantId, status])
  @@index([listingId, status])
  @@index([createdAt])
}

model DeveloperEarning {
  id          String   @id @default(uuid())
  profileId   String
  orderId     String?
  amount      BigInt
  currency    String   @default("VND")
  type        String   // 'sale' | 'commission' | 'bonus' | 'payout'
  description String?
  referenceType String?
  referenceId   String?
  createdAt   DateTime @default(now())

  profile DeveloperProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, type])
  @@index([profileId, createdAt])
  @@index([referenceType, referenceId])
}

// ----------------------------------------------------------------------
// -- Marketplace Versioning & Dependency (Phase 4) -------------------
// Module: apps/api/src/marketplace/
// ----------------------------------------------------------------------

enum VersionStatus {
  ACTIVE
  DEPRECATED
  SUPERSEDED
}

model MarketplaceVersion {
  id          String   @id @default(uuid())
  listingId   String
  version     String          // "1.2.3" — semver
  changelog   String?
  config      Json?           // snapshot of listing config at this version
  status      VersionStatus   @default(ACTIVE)
  publishedAt DateTime        @default(now())

  listing      MarketplaceListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dependencies MarketplaceDependency[] @relation("versionDependencies")
  dependents   MarketplaceDependency[] @relation("versionDependents")
  installs     MarketplaceInstallEvent[]

  @@unique([listingId, version])
  @@index([listingId, status])
}

model MarketplaceDependency {
  id           String   @id @default(uuid())
  versionId    String           // dependent version
  dependsOnId  String           // dependency version
  constraint   String           // ">=1.0.0 <2.0.0" — semver range
  isOptional   Boolean  @default(false)
  createdAt    DateTime @default(now())

  version   MarketplaceVersion @relation("versionDependencies", fields: [versionId], references: [id], onDelete: Cascade)
  dependsOn MarketplaceVersion @relation("versionDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([versionId, dependsOnId])
  @@index([dependsOnId])
}

model MarketplaceReviewAction {
  id           String   @id @default(uuid())
  listingId    String
  reviewerId   String          // tenantId c?a admin/mod
  action       String          // 'SUBMITTED' | 'APPROVED' | 'REJECTED' | 'FLAGGED' | 'CHANGES_REQUESTED'
  reason       String?
  configDiff   Json?           // what changed since last review
  reviewerNote String?
  createdAt    DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
  @@index([reviewerId])
}

model MarketplaceInstallEvent {
  id             String   @id @default(uuid())
  listingId      String
  versionId      String?
  buyerTenantId  String
  eventType      String   // 'INSTALL' | 'UNINSTALL' | 'UPGRADE' | 'DOWNGRADE'
  oldVersion     String?
  newVersion     String?
  createdAt      DateTime @default(now())

  listing MarketplaceListing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  version MarketplaceVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@index([listingId, createdAt])
  @@index([buyerTenantId])
}

// -- End Marketplace Versioning & Dependency ------------------------
// ----------------------------------------------------------------------

