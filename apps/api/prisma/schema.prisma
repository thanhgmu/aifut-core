generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

enum SessionType {
  PASSWORD
  MAGIC_LINK
  OAUTH
  API_KEY
  SERVICE
}

enum IntegrationCategory {
  STORAGE
  DATABASE
  WORKFLOW
  AI
  COMMUNICATION
  ANALYTICS
  PAYMENTS
  OTHER
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
  ERROR
}

enum EntitlementKind {
  FEATURE
  LIMIT
  STORAGE
  USAGE_CREDIT
}

enum TenantDomainKind {
  PLATFORM_SUBDOMAIN
  CUSTOM
  AFFILIATE_DOMAIN
}

enum TenantDomainStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
}

enum TenantStorageMode {
  PLATFORM_MANAGED
  TENANT_MANAGED
  HYBRID
  DISABLED
}

enum AuditActorType {
  USER
  SYSTEM
  SERVICE
}

model Tenant {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  workspaces         Workspace[]
  users              User[]
  memberships        Membership[]
  sessions           Session[]
  integrations       IntegrationConnection[]
  entitlements       Entitlement[]
  auditEvents        AuditEvent[]
  auditLogs          AuditLog[]
  domains            TenantDomain[]
  storagePolicies    TenantStoragePolicy[]
  packageAssignments TenantPackageAssignment[]
}

model Workspace {
  id                 String                  @id @default(cuid())
  name               String
  slug               String
  tenantId           String
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  integrations       IntegrationConnection[]
  domains            TenantDomain[]
  storagePolicies    TenantStoragePolicy[]
  packageAssignments TenantPackageAssignment[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([tenantId, slug])
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  sessions      Session[]
  auditEvents   AuditEvent[]
  auditLogs     AuditLog[]   @relation("AuditActorLogs")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Membership {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String?
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  role         MembershipRole
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([tenantId, userId, workspaceId, role])
  @@index([tenantId, userId])
  @@index([workspaceId])
}

model Session {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           SessionType
  tokenHash      String       @unique
  refreshHash    String?
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model IntegrationConnection {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId        String?
  workspace          Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name               String
  slug               String
  category           IntegrationCategory
  provider           String
  status             ConnectionStatus    @default(PENDING)
  config             Json?
  secretsRef         String?
  mappingMode        String?
  mappedObjects      String[]            @default([])
  fieldMappings      Json?
  eventMappings      Json?
  syncPolicy         Json?
  routingMode        String?
  targetBaseUrl      String?
  targetEnvironment  String?
  targetRegion       String?
  lastVerifiedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, category])
  @@index([workspaceId])
}

model Entitlement {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  kind        EntitlementKind
  value       String
  source      String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, key])
}

model AuditEvent {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType     AuditActorType
  action        String
  targetType    String?
  targetId      String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([tenantId, action])
  @@index([userId])
  @@index([createdAt])
}

model TenantDomain {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId        String?
  workspace          Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  hostname           String
  kind               TenantDomainKind
  status             TenantDomainStatus @default(PENDING)
  isPrimary          Boolean            @default(false)
  provider           String?
  provisioningMode   String?
  dnsTarget          String?
  certificateStatus  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([hostname])
  @@index([tenantId, status])
  @@index([workspaceId])
}

model TenantStoragePolicy {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  key              String
  mode             TenantStorageMode
  storageClass     String?
  targetRef        String?
  targetRegion     String?
  backupTargetRef  String?
  meteringEnabled  Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, mode])
  @@index([workspaceId])
}

model TenantPackageAssignment {
  id                String      @id @default(cuid())
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  scopeKey          String      @unique
  basePlanKey       String
  selectedOptions   String[]    @default([])
  billingSnapshot   Json?
  provisioningState String?
  source            String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId, basePlanKey])
  @@index([workspaceId])
}

model OrchestrationRuntimeSnapshot {
  id              String   @id @default(cuid())
  snapshotKey     String   @unique
  planId          String
  snapshotType    String
  runtimeStatus   String
  tenantSlug      String
  workspaceSlug   String?
  recordedBy      String
  contractSummary Json
  summary         Json
  mutationRecords Json
  eventRecords    Json
  createdAt       DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, snapshotType])
}

model OrchestrationRuntimeEvent {
  id            String   @id @default(cuid())
  eventKey      String   @unique
  planId        String
  eventType     String
  runtimeStatus String
  tenantSlug    String
  workspaceSlug String?
  actorKey      String
  relatedKeys   Json
  metadata      Json
  recordedAt    DateTime
  createdAt     DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, eventType])
  @@index([recordedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditActorLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}
