// в”Ђв”Ђ Wallet / Ledger (Internal Balance Tracking) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum LedgerTransactionType {
  CREDIT
  DEBIT
}

model Wallet {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  balance   BigInt   @default(0) // stored in smallest unit (satang/satoshi), avoid float errors
  version   Int      @default(1) // optimistic lock version, incremented on every write
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions LedgerTransaction[] @relation("walletLedger")
}

model LedgerTransaction {
  id            String                @id @default(cuid())
  tenantId      String
  type          LedgerTransactionType
  amount        BigInt // positive value, sign determined by type
  balanceAfter  BigInt // snapshot of wallet balance after this transaction
  referenceType String // e.g. 'invoice', 'payout', 'commission', 'topup'
  referenceId   String // ID of the referenced entity
  description   String?
  metadata      Json?
  createdAt     DateTime              @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wallet Wallet @relation("walletLedger", fields: [tenantId], references: [tenantId], onDelete: Cascade, map: "LedgerTransaction_wallet_tenantId_fkey")

  @@unique([tenantId, referenceType, referenceId])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([referenceType, referenceId])
}

// в”Ђв”Ђ Refund Engine в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
}

model RefundRecord {
  id                  String       @id @default(uuid())
  originalReferenceId String
  amount              BigInt
  status              RefundStatus @default(PENDING)
  tenantId            String
  createdAt           DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([originalReferenceId, id])
  @@index([tenantId])
  @@index([status])
  @@index([originalReferenceId])
}

// в”Ђв”Ђ Financial Reconciliation Engine (Phase 3) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Дђб»‘i soГЎt chГ©o 3 nguб»“n sб»± thбє­t: Wallet.balance / LedgerTransaction / Invoice.
// Module: apps/api/src/payments/reconciliation/
// KhГіa ngoбєЎi Д‘Ж°б»Јc Д‘бє·t tГЄn map tЖ°б»ќng minh Д‘б»ѓ trГЎnh xung Д‘б»™t vб»›i cГЎc quan hб»‡ khГЎc.

enum ReconciliationStatus {
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

enum DiscrepancyType {
  BALANCE_MISMATCH // LedgerTransaction tб»•ng в‰  Wallet.balance
  MISSING_LEDGER_CREDIT_FOR_PAID_INVOICE // Invoice paid nhЖ°ng thiбєїu LedgerTransaction CREDIT
  ORPHAN_LEDGER_CREDIT // Ledger CREDIT nhЖ°ng Invoice vбє«n pending
  UNMATCHED_DEBIT // LedgerTransaction khГґng cГі PaymentTransaction tЖ°ЖЎng б»©ng
  DUPLICATE_REFERENCE // Nhiб»Ѓu LedgerTransaction cГ№ng reference
  AMOUNT_MISMATCH // LedgerTransaction amount в‰  Invoice.amount
  SUSPICIOUS_ACTIVITY // Anti-fraud heuristic phГЎt hiб»‡n
}

enum DiscrepancySeverity {
  INFO
  WARNING
  CRITICAL
}

enum DiscrepancyResolutionStatus {
  OPEN
  ACKNOWLEDGED
  INVESTIGATING
  RESOLVED_MANUAL
  RESOLVED_AUTO
  DISMISSED
}

enum WalletFreezeReason {
  RECONCILIATION_DISCREPANCY
  SUSPICIOUS_LEDGER_ACTIVITY
  ANTI_FRAUD_TRIGGER
  MANUAL_ADMIN
}

enum ReportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

model ReconciliationRun {
  id               String               @id @default(cuid())
  tenantId         String
  trigger          String // 'scheduled' | 'manual' | 'webhook'
  startedAt        DateTime             @default(now())
  completedAt      DateTime?
  status           ReconciliationStatus @default(RUNNING)
  walletBalance    BigInt? // wallet.balance tбєЎi thб»ќi Д‘iб»ѓm snapshot
  ledgerSum        BigInt? // SUM(CREDIT) - SUM(DEBIT) tбєЎi thб»ќi Д‘iб»ѓm snapshot
  paidInvoiceSum   BigInt? // SUM(Invoice.amount) WHERE status='paid'
  discrepancyCount Int                  @default(0)
  summary          Json? // JSON bГЎo cГЎo rГєt gб»Ќn
  error            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  discrepancies DiscrepancyRecord[]

  @@index([tenantId, startedAt])
  @@index([tenantId, status])
}

model DiscrepancyRecord {
  id              String                      @id @default(cuid())
  runId           String?
  tenantId        String
  severity        DiscrepancySeverity         @default(WARNING)
  category        DiscrepancyType
  title           String // NgбєЇn gб»Ќn, vГ­ dб»Ґ: "Wallet lб»‡ch -5,000 VND"
  description     String? // Chi tiбєїt
  expectedValue   BigInt?
  actualValue     BigInt?
  diffValue       BigInt?
  source          String // 'wallet' | 'ledger' | 'invoice' | 'all'
  affectedEntity  String? // ID cб»§a entity liГЄn quan
  affectedType    String? // 'Wallet' | 'LedgerTransaction' | 'Invoice'
