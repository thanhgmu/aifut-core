generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  MEMBER
  VIEWER
}

enum SessionType {
  PASSWORD
  MAGIC_LINK
  OAUTH
  API_KEY
  SERVICE
}

enum IntegrationCategory {
  STORAGE
  DATABASE
  WORKFLOW
  AI
  COMMUNICATION
  ANALYTICS
  PAYMENTS
  OTHER
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
  ERROR
}

enum EntitlementKind {
  FEATURE
  LIMIT
  STORAGE
  USAGE_CREDIT
}

enum TenantDomainKind {
  PLATFORM_SUBDOMAIN
  CUSTOM
  AFFILIATE_DOMAIN
}

enum TenantDomainStatus {
  PENDING
  ACTIVE
  DEGRADED
  DISABLED
}

enum TenantStorageMode {
  PLATFORM_MANAGED
  TENANT_MANAGED
  HYBRID
  DISABLED
}

enum AuditActorType {
  USER
  SYSTEM
  SERVICE
}

model Tenant {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  workspaces         Workspace[]
  users              User[]
  memberships        Membership[]
  sessions           Session[]
  integrations       IntegrationConnection[]
  entitlements       Entitlement[]
  auditEvents        AuditEvent[]
  auditLogs          AuditLog[]
  domains            TenantDomain[]
  storagePolicies    TenantStoragePolicy[]
  packageAssignments TenantPackageAssignment[]
  workflowTemplates   WorkflowTemplate[]
  workflowExecutions  WorkflowExecution[]
  backupSchedules     BackupSchedule[]
  backupJobs          BackupJob[]
}

model Workspace {
  id                 String                  @id @default(cuid())
  name               String
  slug               String
  tenantId           String
  tenant             Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships        Membership[]
  integrations       IntegrationConnection[]
  domains            TenantDomain[]
  storagePolicies    TenantStoragePolicy[]
  packageAssignments TenantPackageAssignment[]
  workflowTemplates   WorkflowTemplate[]
  workflowExecutions  WorkflowExecution[]
  backupSchedules     BackupSchedule[]
  backupJobs          BackupJob[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([tenantId, slug])
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships   Membership[]
  sessions      Session[]
  auditEvents   AuditEvent[]
  auditLogs     AuditLog[]   @relation("AuditActorLogs")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Membership {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId  String?
  workspace    Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  role         MembershipRole
  isDefault    Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([tenantId, userId, workspaceId, role])
  @@index([tenantId, userId])
  @@index([workspaceId])
}

model Session {
  id             String       @id @default(cuid())
  tenantId       String
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           SessionType
  tokenHash      String       @unique
  refreshHash    String?
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId, userId])
  @@index([expiresAt])
}

model IntegrationConnection {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId        String?
  workspace          Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name               String
  slug               String
  category           IntegrationCategory
  provider           String
  status             ConnectionStatus    @default(PENDING)
  config             Json?
  secretsRef         String?
  mappingMode        String?
  mappedObjects      String[]            @default([])
  fieldMappings      Json?
  eventMappings      Json?
  syncPolicy         Json?
  routingMode        String?
  targetBaseUrl      String?
  targetEnvironment  String?
  targetRegion       String?
  lastVerifiedAt     DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, category])
  @@index([workspaceId])
}

model Entitlement {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key         String
  kind        EntitlementKind
  value       String
  source      String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, key])
}

model AuditEvent {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorType     AuditActorType
  action        String
  targetType    String?
  targetId      String?
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([tenantId, action])
  @@index([userId])
  @@index([createdAt])
}

model TenantDomain {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId        String?
  workspace          Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  hostname           String
  kind               TenantDomainKind
  status             TenantDomainStatus @default(PENDING)
  isPrimary          Boolean            @default(false)
  provider           String?
  provisioningMode   String?
  dnsTarget          String?
  certificateStatus  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([hostname])
  @@index([tenantId, status])
  @@index([workspaceId])
}

model TenantStoragePolicy {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId      String?
  workspace        Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  key              String
  mode             TenantStorageMode
  storageClass     String?
  targetRef        String?
  targetRegion     String?
  backupTargetRef  String?
  meteringEnabled  Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId, mode])
  @@index([workspaceId])
}

model TenantPackageAssignment {
  id                String      @id @default(cuid())
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspaceId       String?
  workspace         Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  scopeKey          String      @unique
  basePlanKey       String
  selectedOptions   String[]    @default([])
  billingSnapshot   Json?
  provisioningState String?
  source            String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId, basePlanKey])
  @@index([workspaceId])
}

model OrchestrationRuntimeSnapshot {
  id              String   @id @default(cuid())
  snapshotKey     String   @unique
  planId          String
  snapshotType    String
  runtimeStatus   String
  tenantSlug      String
  workspaceSlug   String?
  recordedBy      String
  recordedAt      DateTime
  contractSummary Json
  summary         Json
  mutationRecords Json
  eventRecords    Json
  createdAt       DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, snapshotType])
  @@index([recordedAt])
}

model OrchestrationRuntimeEvent {
  id            String   @id @default(cuid())
  eventKey      String   @unique
  planId        String
  eventType     String
  runtimeStatus String
  tenantSlug    String
  workspaceSlug String?
  actorKey      String
  relatedKeys   Json
  metadata      Json
  recordedAt    DateTime
  createdAt     DateTime @default(now())

  @@index([tenantSlug, planId])
  @@index([planId, eventType])
  @@index([recordedAt])
}

model AiRoutingPolicy {
  id                         String   @id @default(cuid())
  policyKey                  String   @unique
  scopeType                  String
  tenantSlug                 String
  workspaceSlug              String?
  featureKey                 String
  taskType                   String
  defaultLane                String
  maxLane                    String
  preferredCredentialMode    String
  allowByoKeys               Boolean  @default(false)
  requireApprovalAboveLane   String?
  downgradeAtQuotaPressure   String
  cacheEnabled               Boolean  @default(true)
  deterministicFirst         Boolean  @default(true)
  source                     String
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([tenantSlug, featureKey])
  @@index([workspaceSlug])
  @@index([defaultLane])
}

model AiBudgetPolicy {
  id                             String   @id @default(cuid())
  policyKey                      String   @unique
  scopeType                      String
  tenantSlug                     String
  workspaceSlug                  String?
  featureKey                     String
  monthlyTokenBudget             Int      @default(0)
  hardMonthlyTokenLimit          Int      @default(0)
  premiumExecutionCap            Int      @default(0)
  blockOnHardLimit               Boolean  @default(true)
  requireApprovalAtProjectedCost Float    @default(0)
  source                         String
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  @@index([tenantSlug, featureKey])
  @@index([workspaceSlug])
}

model AiUsageEvent {
  id                  String   @id @default(cuid())
  eventKey            String   @unique
  scopeType           String
  tenantSlug          String
  workspaceSlug       String?
  actorKey            String
  featureKey          String
  taskType            String
  providerKey         String
  modelKey            String
  credentialMode      String
  executionLane       String
  inputTokens         Int      @default(0)
  outputTokens        Int      @default(0)
  totalTokens         Int      @default(0)
  estimatedCost       Float    @default(0)
  actualCost          Float    @default(0)
  cacheHit            Boolean  @default(false)
  retryCount          Int      @default(0)
  escalationCount     Int      @default(0)
  status              String
  source              String
  occurredAt          DateTime
  createdAt           DateTime @default(now())

  @@index([tenantSlug, occurredAt])
  @@index([workspaceSlug])
  @@index([featureKey, taskType])
  @@index([executionLane])
  @@index([status])
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  DISABLED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum WorkflowNodeType {
  TRIGGER
  ACTION
  CONDITION
  WAIT
  SEND
  TRANSFORM
  LOOP
  SUB_WORKFLOW
}

enum WorkflowTriggerKind {
  SCHEDULE
  WEBHOOK
  EVENT
  MANUAL
}

model WorkflowTemplate {
  id              String                @id @default(cuid())
  tenantId        String
  workspaceId     String?
  key             String
  name            String
  description     String?
  category        String?
  industry        String?
  status          WorkflowStatus        @default(DRAFT)
  version         Int                   @default(1)
  tags            String[]              @default([])
  metadata        Json?
  source          String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace?            @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  nodes           WorkflowNode[]
  executions      WorkflowExecution[]
  triggers        WorkflowTrigger[]

  @@unique([tenantId, key])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([industry])
}

model WorkflowNode {
  id              String                @id @default(cuid())
  workflowId      String
  key             String
  name            String
  nodeType        WorkflowNodeType
  position        Int                   @default(0)
  config          Json?
  inputMapping    Json?
  outputMapping   Json?
  retryPolicy     Json?
  timeoutSeconds  Int                   @default(300)
  dependsOn       String[]              @default([])
  metadata        Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  workflow        WorkflowTemplate      @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([workflowId, nodeType])
  @@index([workflowId, position])
}

model WorkflowTrigger {
  id              String                @id @default(cuid())
  workflowId      String
  kind            WorkflowTriggerKind
  config          Json?
  schedule        String?               // cron expression
  webhookSecret   String?
  eventType       String?
  enabled         Boolean               @default(true)
  lastFiredAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  workflow        WorkflowTemplate      @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, kind])
  @@index([eventType])
}

model WorkflowExecution {
  id              String                    @id @default(cuid())
  workflowId      String
  tenantId        String
  workspaceId     String?
  triggerKind     WorkflowTriggerKind?
  triggeredBy     String?
  status          WorkflowExecutionStatus   @default(PENDING)
  input           Json?
  output          Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  timeoutAt       DateTime?
  retryCount      Int                       @default(0)
  maxRetries      Int                       @default(3)
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  workflow        WorkflowTemplate          @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  tenant          Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace?                @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  steps           WorkflowExecutionStep[]

  @@index([workflowId, status])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([triggerKind])
}

model WorkflowExecutionStep {
  id              String                    @id @default(cuid())
  executionId     String
  nodeId          String?
  nodeKey         String
  status          WorkflowExecutionStatus   @default(PENDING)
  input           Json?
  output          Json?
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  retryCount      Int                       @default(0)
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  execution       WorkflowExecution         @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, nodeKey])
  @@index([executionId, status])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditActorLogs", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

enum BackupJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

model BackupSchedule {
  id              String        @id @default(cuid())
  tenantId        String
  workspaceId     String?
  key             String
  name            String
  description     String?
  cronExpression  String?       // null = manual only
  targetRef       String        // storage target reference
  backupMode      String        // 'full', 'incremental', 'diff'
  retentionDays   Int           @default(30)
  maxBackups      Int           @default(10)
  enabled         Boolean       @default(true)
  lastRunAt       DateTime?
  lastStatus      String?
  config          Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  jobs            BackupJob[]

  @@unique([tenantId, key])
  @@index([tenantId, enabled])
  @@index([workspaceId])
}

model BackupJob {
  id              String           @id @default(cuid())
  scheduleId      String
  tenantId        String
  workspaceId     String?
  status          BackupJobStatus  @default(PENDING)
  backupTarget    String?
  startedAt       DateTime?
  completedAt     DateTime?
  totalSize       Int?             // bytes
  fileCount       Int?
  error           String?
  log             String?
  retryCount      Int              @default(0)
  triggeredBy     String?          // 'schedule', 'manual', 'api'
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  schedule        BackupSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace       Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([scheduleId, status])
  @@index([tenantId, status])
  @@index([workspaceId])
  @@index([startedAt])
}
