// -- E-Invoice (Hoa don dien tu GTGT) ---------------------------------

model InvoiceCounter {
  id           String   @id @default(cuid())
  tenantId     String
  serialSymbol String
  counter      Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, serialSymbol])
  @@index([tenantId])
