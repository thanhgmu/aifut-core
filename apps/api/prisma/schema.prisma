// в”Ђв”Ђ Anti-Drain Budget Caps (Phase 4) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Cost-based AI budget enforcement theo period DAILY/WEEKLY/MONTHLY (VND, BigInt).
// ChбєЎy song song vб»›i AiBudgetPolicy (token-based) вЂ” module nГ y lo CHI PHГЌ (VND).
// Module: apps/api/src/payments/budget/
// State machine: ACTIVE в†’ SOFT_LOCKED (vЖ°б»Јt alertThreshold) в†’ HARD_LOCKED (chбєЎm maxCostAmount).
// Cron reset currentCostSpent = 0 khi periodEnd < now.

enum BudgetPeriod {
  DAILY
  WEEKLY

  MONTHLY
}

enum BudgetStatus {
  ACTIVE // CГІn hбєЎn mб»©c, mб»Ќi request AI Д‘Ж°б»Јc phГ©p
  SOFT_LOCKED // VЖ°б»Јt alertThreshold (mбє·c Д‘б»‹nh 80%), chбє·n AI request mб»›i khГґng Ж°u tiГЄn
  HARD_LOCKED // ChбєЎm maxCostAmount, chбє·n HOГЂN TOГЂN mб»Ќi request AI
}

model AiBudgetLimit {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // в”Ђв”Ђ CбєҐu hГ¬nh hбєЎn mб»©c в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  maxCostAmount BigInt // Sб»‘ tiб»Ѓn tб»‘i Д‘a (VND, BigInt trГЎnh mбєҐt precision)
  currency      String       @default("VND")
  period        BudgetPeriod // DAILY | WEEKLY | MONTHLY

  // в”Ђв”Ђ TrбєЎng thГЎi luб»№ kбєї в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  currentCostSpent BigInt       @default(0) // Tiб»Ѓn Д‘ГЈ tiГЄu luб»№ kбєї trong kб»і hiб»‡n tбєЎi (VND)
  status           BudgetStatus @default(ACTIVE)

  // в”Ђв”Ђ NgЖ°б»Ўng cбєЈnh bГЎo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  alertThreshold Float @default(0.8) // 0.0 вЂ“ 1.0, mбє·c Д‘б»‹nh 80%

  // в”Ђв”Ђ Timestamps period в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  periodStart  DateTime // Thб»ќi Д‘iб»ѓm bбєЇt Д‘бє§u kб»і hiб»‡n tбєЎi
  periodEnd    DateTime // Thб»ќi Д‘iб»ѓm kбєїt thГєc kб»і hiб»‡n tбєЎi
  lastResetAt  DateTime? // Lбє§n reset gбє§n nhбєҐt
  softLockedAt DateTime? // Thб»ќi Д‘iб»ѓm chuyб»ѓn sang SOFT_LOCKED
  hardLockedAt DateTime? // Thб»ќi Д‘iб»ѓm chuyб»ѓn sang HARD_LOCKED

  // в”Ђв”Ђ Notification anti-spam в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  lastAlertSentAt DateTime? // TrГЎnh spam: chб»‰ gб»­i alert khi lбє§n cuб»‘i > cooldown

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@index([periodEnd])
}

