# ── Region: Thailand (TH) ─────────────────────────
REGION=th
DOMAIN=aifut.co.th
API_DOMAIN=api.aifut.co.th
DEFAULT_LOCALE=th
DEFAULT_CURRENCY=THB
TZ=Asia/Bangkok

# ── Database ────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=
PG_DB=aifut_th

# ── Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────
API_PORT=3002

# ── Payment Gateways (Thailand) ─────────────────
# PromptPay / TrueMoney could be added as connectors
STRIPE_SECRET_KEY=

# ── Web ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.co.th

# ── AI Routing ──────────────────────────────────
AI_REGION=ap-southeast-1
AI_MODEL_DEFAULT=gpt-4o-mini
