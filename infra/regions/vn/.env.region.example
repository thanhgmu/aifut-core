# ── Region: Vietnam (VN) ──────────────────────────
REGION=vn
DOMAIN=aifut.vn
API_DOMAIN=api.aifut.vn
DEFAULT_LOCALE=vi
DEFAULT_CURRENCY=VND
TZ=Asia/Ho_Chi_Minh

# ── Database ────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=
PG_DB=aifut_vn

# ── Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────
API_PORT=3002

# ── Payment Gateways (Vietnam) ──────────────────
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ── Web ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.vn

# ── AI Routing ──────────────────────────────────
AI_REGION=vn-central-1
AI_MODEL_DEFAULT=gpt-4o-mini
