# ── Region: Singapore (SG) ─────────────────────────
REGION=sg
DOMAIN=aifut.sg
API_DOMAIN=api.aifut.sg
DEFAULT_LOCALE=en
DEFAULT_CURRENCY=SGD
TZ=Asia/Singapore

# ── Database ────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=
PG_DB=aifut_sg

# ── Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────
API_PORT=3002

# ── Payment Gateways (SEA) ──────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# GrabPay / FPX could be added as connectors

# ── Web ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.sg

# ── AI Routing ──────────────────────────────────
AI_REGION=ap-southeast-1
AI_MODEL_DEFAULT=gpt-4o-mini
