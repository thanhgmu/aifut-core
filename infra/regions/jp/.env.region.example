# ── Region: Japan (JP) ────────────────────────────
REGION=jp
DOMAIN=aifut.jp
API_DOMAIN=api.aifut.jp
DEFAULT_LOCALE=ja
DEFAULT_CURRENCY=JPY
TZ=Asia/Tokyo

# ── Database ────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=
PG_DB=aifut_jp

# ── Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────
API_PORT=3002

# ── Payment Gateways (Japan) ────────────────────
# PayPay / Konbini / Stripe
STRIPE_SECRET_KEY=

# ── Web ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.jp

# ── AI Routing ──────────────────────────────────
AI_REGION=ap-northeast-1
AI_MODEL_DEFAULT=gpt-4o-mini
