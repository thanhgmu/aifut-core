# ── Region: United States (US) ─────────────────────
REGION=us
DOMAIN=aifut.us
API_DOMAIN=api.aifut.us
DEFAULT_LOCALE=en
DEFAULT_CURRENCY=USD
TZ=America/Los_Angeles

# ── Database ────────────────────────────────────
PG_USER=aifut
PG_PASSWORD=
PG_DB=aifut_us

# ── Auth ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── API ─────────────────────────────────────────
API_PORT=3002

# ── Payment Gateways (Global) ───────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Web ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.aifut.us

# ── AI Routing ──────────────────────────────────
AI_REGION=us-west-2
AI_MODEL_DEFAULT=gpt-4o-mini
