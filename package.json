{
  "name": "aifut-core",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "local:verify-runtime": "npm run local:verify-runtime --workspace apps/api && npm run local:verify-runtime --workspace apps/web",
    "prisma:generate": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prisma": "^7.8.0",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "^20.19 || ^22.12 || >=24.0"
  },
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
